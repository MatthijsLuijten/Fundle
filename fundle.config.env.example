# =============================================================================
# Fundle — copy to fundle.config.env and adjust locally (not committed to git)
# Sync naar apps/api/.env en apps/web/.env.local gebeurt automatisch bij npm run dev
# =============================================================================

# --- Spelmodus ---
# 1 = vaste demo-woning (Luttenberg, geen Funda API nodig)
# 0 = echte Funda-listing (puzzel wordt automatisch opnieuw gebouwd bij wisselen)
DEMO_MODE=1

# 1 = elke pagina-refresh reset gokken en bouwt puzzel opnieuw (alleen voor dev)
# 0 = normale daily sessie (gokken blijven bewaard)
DEBUG_FRESH=0

# --- API ---
DATABASE_URL=sqlite+pysqlite:///./fundle.db
CORS_ORIGINS=http://localhost:3000

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:8000
