# SQLite (default, no Docker)
DATABASE_URL=sqlite+pysqlite:///./fundle.db

# PostgreSQL (docker compose up -d)
# DATABASE_URL=postgresql+psycopg://fundle:fundle@localhost:5432/fundle

CORS_ORIGINS=http://localhost:3000
# 1 = fixed demo listing; 0 = fetch from Funda via pyfunda
DEMO_MODE=1
# 1 = reset guesses on each page load; rebuild today's puzzle (dev only)
DEBUG_FRESH_SESSION=0
